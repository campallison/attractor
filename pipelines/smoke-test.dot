digraph SmokeTest {
	graph [goal="Verify pipeline engine integration after refactoring"]
	rankdir=LR

	start [shape=Mdiamond, label="Start"]
	exit  [shape=Msquare, label="Exit"]

	plan [
		shape=box,
		label="Plan",
		prompt="Plan a simple change. $prior_context"
	]

	implement [
		shape=box,
		label="Implement",
		prompt="Implement the planned change. $prior_context",
		check_cmd="echo 'check passed'",
		check_max_retries=2,
		goal_gate=true
	]

	verify [
		shape=box,
		label="Verify",
		prompt="Verify the implementation is correct. $prior_context"
	]

	start -> plan -> implement -> verify -> exit
	implement -> plan [condition="outcome=fail", label="retry"]
}
